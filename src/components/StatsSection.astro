---
import vaRates from '../data/vaRates.json';

const formatCurrency = (val: number) => {
  return `$${val.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
};
---

<section class="stats-section">
  <header class="hero-header">
    <h1>{vaRates.metadata.headerTitle}</h1>
    <p>{vaRates.metadata.headerDescription}</p>
  </header>

  <main class="main-content">
    
    <!-- Table Section 1: Without Children -->
    <section class="table-section" id="rates-without-children">
      <h2>Rates Without Dependent Children</h2>
      <div class="table-wrapper">
        <table class="rate-table" aria-labelledby="rates-without-children">
          <caption>Monthly payment amounts for veterans without dependent children.</caption>
          <thead>
            <tr>
              <th scope="col">Disability Rating</th>
              <th scope="col">Veteran Alone</th>
              <th scope="col">Veteran with Spouse</th>
              <th scope="col">Veteran, Spouse & One Parent</th>
              <th scope="col">Veteran, Spouse and Two Parents</th>
              <th scope="col">Veteran with One Parent</th>
              <th scope="col">Veteran with Two Parents</th>
            </tr>
          </thead>
          <tbody>
            {vaRates.withoutChildren.map((row) => (
              <tr>
                <th scope="row">{row.rating}</th>
                <td data-label="Veteran Alone">{formatCurrency(row.alone)}</td>
                <td data-label="Veteran with Spouse">{formatCurrency(row.spouse)}</td>
                <td data-label="Veteran, Spouse & One Parent">{formatCurrency(row.spouseOneParent)}</td>
                <td data-label="Veteran, Spouse and Two Parents">{formatCurrency(row.spouseTwoParents)}</td>
                <td data-label="Veteran with One Parent">{formatCurrency(row.oneParent)}</td>
                <td data-label="Veteran with Two Parents">{formatCurrency(row.twoParents)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Table Section 3: Additional Compensation -->
    <section class="table-section" id="additional-compensation">
      <h2>Additional Compensation for Aid & Attendance (A/A)</h2>
      <div class="table-wrapper">
        <table class="rate-table" aria-labelledby="additional-compensation">
          <caption>Additional monthly payment amounts for spouses requiring Aid and Attendance.</caption>
          <thead>
            <tr>
              <th scope="col">Dependent Status</th>
              <th scope="col">100%</th>
              <th scope="col">90%</th>
              <th scope="col">80%</th>
              <th scope="col">70%</th>
              <th scope="col">60%</th>
              <th scope="col">50%</th>
              <th scope="col">40%</th>
              <th scope="col">30%</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">Additional for A/A Spouse</th>
              <td data-label="100%">{formatCurrency(vaRates.aidAndAttendance["100"])}</td>
              <td data-label="90%">{formatCurrency(vaRates.aidAndAttendance["90"])}</td>
              <td data-label="80%">{formatCurrency(vaRates.aidAndAttendance["80"])}</td>
              <td data-label="70%">{formatCurrency(vaRates.aidAndAttendance["70"])}</td>
              <td data-label="60%">{formatCurrency(vaRates.aidAndAttendance["60"])}</td>
              <td data-label="50%">{formatCurrency(vaRates.aidAndAttendance["50"])}</td>
              <td data-label="40%">{formatCurrency(vaRates.aidAndAttendance["40"])}</td>
              <td data-label="30%">{formatCurrency(vaRates.aidAndAttendance["30"])}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Info Notice Section -->
    <section class="info-notice">
      <p>Veterans with ratings of 10%-20% do not receive extra compensation for dependents</p>
      <div class="rates">
        <span>10% Rate = {formatCurrency(vaRates.flatRates["10"])}</span>
        <span>•</span>
        <span>20% Rate = {formatCurrency(vaRates.flatRates["20"])}</span>
      </div>
    </section>

    <!-- Call to Action Section -->
    <section class="cta-section">
      <a href="/#get-started" class="cta-button">Schedule Free Consultation</a>
    </section>

    <!-- Table Section 2: With Children -->
    <section class="table-section" id="rates-with-children">
      <h2>Rates With Dependent Children</h2>
      <div class="table-wrapper">
        <table class="rate-table" aria-labelledby="rates-with-children">
          <caption>Monthly payment amounts for veterans with dependent children.</caption>
          <thead>
            <tr>
              <th scope="col">Disability Rating</th>
              <th scope="col">Veteran and Child</th>
              <th scope="col">Veteran, Spouse, & Child</th>
              <th scope="col">Veteran, Spouse, Child, One Parent</th>
              <th scope="col">Veteran, Spouse, Child, Two Parents</th>
              <th scope="col">Veteran, Child, One Parent</th>
              <th scope="col">Veteran, Child, Two Parents</th>
            </tr>
          </thead>
          <tbody>
            {vaRates.withChildren.map((row) => (
              <tr>
                <th scope="row">{row.rating}</th>
                <td data-label="Veteran and Child">{formatCurrency(row.child)}</td>
                <td data-label="Veteran, Spouse, & Child">{formatCurrency(row.spouseChild)}</td>
                <td data-label="Veteran, Spouse, Child, One Parent">{formatCurrency(row.spouseChildOneParent)}</td>
                <td data-label="Veteran, Spouse, Child, Two Parents">{formatCurrency(row.spouseChildTwoParents)}</td>
                <td data-label="Veteran, Child, One Parent">{formatCurrency(row.childOneParent)}</td>
                <td data-label="Veteran, Child, Two Parents">{formatCurrency(row.childTwoParents)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Table Section 4: Additional Children -->
    <section class="table-section" id="additional-children">
      <h2>Additional Amounts for Dependent Children</h2>
      <div class="table-wrapper">
        <table class="rate-table" aria-labelledby="additional-children">
          <caption>Additional monthly payment amounts for each additional child.</caption>
          <thead>
            <tr>
              <th scope="col">Dependent Status</th>
              <th scope="col">100%</th>
              <th scope="col">90%</th>
              <th scope="col">80%</th>
              <th scope="col">70%</th>
              <th scope="col">60%</th>
              <th scope="col">50%</th>
              <th scope="col">40%</th>
              <th scope="col">30%</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <th scope="row">Each Additional Child Under Age 18</th>
              <td data-label="100%">{formatCurrency(vaRates.additionalChildUnder18["100"])}</td>
              <td data-label="90%">{formatCurrency(vaRates.additionalChildUnder18["90"])}</td>
              <td data-label="80%">{formatCurrency(vaRates.additionalChildUnder18["80"])}</td>
              <td data-label="70%">{formatCurrency(vaRates.additionalChildUnder18["70"])}</td>
              <td data-label="60%">{formatCurrency(vaRates.additionalChildUnder18["60"])}</td>
              <td data-label="50%">{formatCurrency(vaRates.additionalChildUnder18["50"])}</td>
              <td data-label="40%">{formatCurrency(vaRates.additionalChildUnder18["40"])}</td>
              <td data-label="30%">{formatCurrency(vaRates.additionalChildUnder18["30"])}</td>
            </tr>
            <tr>
              <th scope="row">Each Additional Schoolchild Over Age 18</th>
              <td data-label="100%">{formatCurrency(vaRates.additionalSchoolchildOver18["100"])}</td>
              <td data-label="90%">{formatCurrency(vaRates.additionalSchoolchildOver18["90"])}</td>
              <td data-label="80%">{formatCurrency(vaRates.additionalSchoolchildOver18["80"])}</td>
              <td data-label="70%">{formatCurrency(vaRates.additionalSchoolchildOver18["70"])}</td>
              <td data-label="60%">{formatCurrency(vaRates.additionalSchoolchildOver18["60"])}</td>
              <td data-label="50%">{formatCurrency(vaRates.additionalSchoolchildOver18["50"])}</td>
              <td data-label="40%">{formatCurrency(vaRates.additionalSchoolchildOver18["40"])}</td>
              <td data-label="30%">{formatCurrency(vaRates.additionalSchoolchildOver18["30"])}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

  </main>
</section>

<style>
  .stats-section {
    --color-navy: #1a233f;
    --color-dark-navy: #111827;
    --color-white: #ffffff;
    --color-off-white: #f3f4f6;
    --color-text-light: #d1d5db;
    --color-text-dark: #374151;
    --color-accent-red: #b91c1c;
    --color-border: #e5e7eb;
    font-family: 'Inter', sans-serif;
    background-color: var(--color-off-white);
    color: var(--color-text-dark);
    line-height: 1.6;
  }

  /* Main Header/Hero Section */
  .hero-header {
    background-color: var(--color-navy);
    color: var(--color-white);
    padding: 4rem 1.5rem;
    text-align: center;
    /* Subtle star pattern for a patriotic feel */
    background-image: radial-gradient(var(--color-dark-navy) 1px, transparent 1px);
    background-size: 15px 15px;
  }

  .hero-header h1 {
    font-family: 'Merriweather', serif;
    font-size: 2.5rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .hero-header p {
    font-size: 1.125rem;
    color: var(--color-text-light);
    max-width: 65ch; /* Optimal line length for readability */
    margin: 0 auto;
  }

  /* Main Content Container */
  .main-content {
    padding: 2rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  /* Table Section Styling */
  .table-section {
    background-color: var(--color-white);
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    margin-bottom: 2.5rem;
    overflow: hidden; /* Ensures border-radius is respected by table */
  }

  .table-section h2 {
    font-family: 'Merriweather', serif;
    font-size: 1.75rem;
    padding: 1.5rem;
    color: var(--color-dark-navy);
    border-bottom: 2px solid var(--color-accent-red);
    margin: 0;
  }

  /* Responsive Table Wrapper */
  .table-wrapper {
    overflow-x: auto; /* Allows horizontal scrolling on medium screens if needed */
  }

  /* Table Styles */
  .rate-table {
    width: 100%;
    border-collapse: collapse;
    text-align: center;
  }

  .rate-table caption {
    font-size: 0.875rem;
    color: var(--color-text-dark);
    padding: 1rem;
    caption-side: bottom;
    text-align: left;
  }

  .rate-table thead th {
    background-color: var(--color-off-white);
    padding: 1rem;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    vertical-align: middle;
  }

  .rate-table tbody tr:nth-child(even) {
    background-color: #fafafa;
  }
  
  .rate-table tbody tr:hover {
    background-color: #f0f3ff;
  }

  .rate-table th, .rate-table td {
    padding: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .rate-table tbody th {
    font-weight: 700;
    text-align: right;
    border-right: 1px solid var(--color-border);
  }
  
  /* Icon Styles */
  .dependent-icon {
    display: block;
    margin: 0 auto 0.5rem auto;
    height: 28px;
    width: auto;
    fill: var(--color-navy);
  }

  /* Info Notice Section */
  .info-notice {
    text-align: center;
    padding: 2rem;
    margin: 2.5rem 0;
    background-color: var(--color-white);
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
  }

  .info-notice p {
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--color-text-dark);
    margin-bottom: 1rem;
  }

  .info-notice .rates {
    font-size: 1.125rem;
    font-weight: 500;
  }
  
  .info-notice .rates span {
    margin: 0 1rem;
  }

  /* Call to Action Button */
  .cta-section {
    text-align: center;
    margin: 2rem 0rem;
  }

  .cta-button {
    display: inline-block;
    background-color: var(--color-accent-red);
    color: var(--color-white);
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    padding: 1rem 2.5rem;
    border-radius: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    background-color: #991b1b; /* Darker red */
    transform: translateY(-2px);
  }

  /* Responsive Design for Tables on Mobile */
  @media (max-width: 900px) {
    .hero-header h1 {
      font-size: 2rem;
    }

    /* Hides the regular table header on small screens */
    .rate-table thead {
      display: none;
    }
    
    /* Transforms table rows into cards */
    .rate-table tr {
      display: block;
      border-bottom: 2px solid var(--color-navy);
      margin-bottom: 1.5rem;
    }
    
    /* Hides empty rows */
    .rate-table tr:empty {
      display: none;
    }
    
     .rate-table tbody tr:nth-child(even) {
      background-color: transparent;
    }

    .rate-table td {
      display: flex; /* Use flexbox for alignment */
      justify-content: space-between; /* Pushes label and value apart */
      text-align: right;
      font-size: 1rem;
      border-bottom: 1px solid var(--color-border);
    }

    /* Adds the header label before each data cell */
    .rate-table td::before {
      content: attr(data-label);
      font-weight: 700;
      text-align: left;
      padding-right: 1rem; /* Space between label and value */
      white-space: nowrap;
    }

    /* First cell (percentage) becomes a card header */
    .rate-table tbody th {
      display: block;
      text-align: center;
      font-size: 1.25rem;
      background-color: var(--color-off-white);
      border-right: none;
    }
  }
</style>