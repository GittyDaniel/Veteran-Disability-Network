  <style>
    .testimonials {
      background: var(--color-bg);
      color: var(--color-text);
      padding: 0.5rem 1.5rem clamp(2.5rem, 6vw, 4rem) 1.5rem; /* Reduced top padding to fix the whitespace gap */
      border-top: 1px solid var(--color-border);
    }
    .testimonials-inner { max-width: 76rem; margin: 0 auto; }

    .testimonials-header { text-align: center; margin-bottom: clamp(1.5rem, 4vw, 2.5rem); }
    .testimonials-title {
      font: 800 clamp(1.5rem, 2.2vw + 1rem, 2.25rem) "Merriweather", Georgia, serif;
      line-height: 1.15; margin: 0; color: var(--color-primary);
      text-wrap: balance;
    }
    .testimonials-subtitle {
      font-size: clamp(0.95rem, 1.2vw + 0.75rem, 1.15rem);
      color: var(--color-muted);
      margin: 0.5rem auto 0;
      font-weight: 500;
      max-width: 40rem;
      text-wrap: balance;
      line-height: 1.4;
    }
    .testimonials-subtitle strong {
      color: var(--color-accent);
      font-weight: 700;
    }
    .testimonials-accent {
      display: inline-block; width: 96px; height: 4px; border-radius: 999px;
      margin-top: .8rem;
      background: linear-gradient(90deg, #b22234 0%, var(--color-primary) 100%);
    }

    /* === Testimonials Grid ============================================= */
    .testimonials-grid {
      display: grid;
      grid-template-columns: repeat(1, minmax(0, 1fr));
      gap: 1.5rem;
      transition: all 0.3s ease;
    }

    /* Hidden state */
    .hidden-card {
      display: none !important;
    }

    /* === Speech Cards ================================================ */
    .tcard {
      display: grid;
      grid-template-rows: 1fr auto;
      width: 100%;
      border-radius: 1rem;
      background: #fff;
      color: var(--color-text);
      box-shadow: 0 12px 28px rgba(0,0,0,.08);
      outline: 1px solid var(--color-border);
      outline-offset: -1px;
      overflow: hidden;
      transition: transform .25s ease, box-shadow .25s ease;
    }
    .tcard:hover, .tcard:focus-within {
      transform: translateY(-4px);
      box-shadow: 0 16px 32px rgba(46, 63, 115, 0.12);
    }
    /* patriotic top rule */
    .tcard::before {
      content: "";
      display: block;
      height: 4px;
      background: linear-gradient(90deg, #b22234 0%, var(--color-primary) 100%);
    }

    .tcard-quote {
      position: relative;
      padding: 1.75rem 1.5rem 1.25rem 1.5rem;
    }
    .tcard-quote p {
      margin: 0;
      font-size: 0.95rem;
      line-height: 1.6;
      text-wrap: pretty;
      color: var(--color-text);
    }
    /* Word‑art opening quote on paragraph */
    .tcard-quote p::before {
      content: "“";
      position: absolute;
      top: .3rem; left: .75rem;
      transform: translate(-100%, -15%);  /* sits outside text start */
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 700;
      font-size: clamp(2.4rem, 4.2vw, 3.2rem);
      line-height: 1;
      opacity: .14;
      background: linear-gradient(135deg, #b22234 0%, var(--color-primary) 75%);
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent;
      pointer-events: none; user-select: none;
    }

    .tcard-foot {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: .75rem;
      padding: .85rem 1.5rem 1.15rem;
      border-top: 1px solid var(--color-border);
      background: #fdfdfd;
    }
    .tcard-author {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .tcard-name {
      margin: 0;
      font: 800 1rem "Merriweather", Georgia, serif;
      color: var(--color-primary);
      letter-spacing: .01em;
      line-height: 1.25;
    }
    .tcard-branch {
      font-size: 0.78rem;
      color: var(--color-muted);
      font-weight: 600;
      line-height: 1.2;
    }
    .tcard-status-badge {
      display: inline-block;
      align-self: flex-start;
      font-size: 0.65rem;
      font-weight: 800;
      padding: 0.15rem 0.35rem;
      border-radius: 4px;
      margin-top: 0.25rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      line-height: 1;
    }
    .tcard-status-badge.approved {
      background-color: rgba(16, 124, 65, 0.08);
      color: #107c41;
      border: 1px solid rgba(16, 124, 65, 0.15);
    }
    .tcard-status-badge.increased {
      background-color: rgba(185, 29, 53, 0.06);
      color: var(--color-accent);
      border: 1px solid rgba(185, 29, 53, 0.12);
    }

    .rating { display: inline-flex; align-items: center; gap: .2rem; color: #ffc94d; }
    .star { width: 14px; height: 14px; display:block; }
    .star path { fill: currentColor; }
    .star.dim { opacity: .35; }
    .rating-value { margin-left: .2rem; font-weight: 700; font-size: .8rem; color: var(--color-text); opacity: .75; }

    /* === Toggle Actions =============================================== */
    .testimonials-actions {
      display: flex;
      justify-content: center;
      margin-top: 3rem;
    }
    .btn-testimonials-toggle {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background-color: var(--color-surface);
      color: var(--color-primary);
      border: 2px solid var(--color-primary);
      border-radius: 9999px;
      padding: 0.75rem 1.75rem;
      font-weight: 700;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.25s ease;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
    }
    .btn-testimonials-toggle:hover,
    .btn-testimonials-toggle:focus-visible {
      background-color: var(--color-primary);
      color: var(--color-primary-contrast);
      transform: translateY(-2px);
      box-shadow: 0 6px 12px rgba(46, 63, 115, 0.15);
      outline: none;
    }
    .btn-testimonials-toggle .chevron-icon {
      transition: transform 0.3s ease;
    }
    .btn-testimonials-toggle[aria-expanded="true"] .chevron-icon {
      transform: rotate(180deg);
    }

    /* === Responsive Grid ============================================== */
    @media (min-width: 700px) {
      .testimonials-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (min-width: 1024px) {
      .testimonials-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    /* Mobile ergonomics */
    @media (max-width: 640px) {
      .tcard { border-radius: .9rem; }
      .tcard-quote { padding: 1.25rem 1.25rem .75rem 1.25rem; }
      .tcard-foot { padding: .75rem 1.25rem 1.1rem; }
      .tcard-name { font-size: 0.95rem; }
      .testimonials {
        padding: 0.5rem 1rem clamp(2.5rem, 6vw, 4rem) 1rem;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .tcard, .btn-testimonials-toggle, .btn-testimonials-toggle .chevron-icon { transition: none; }
    }
  </style>

  <!-- Behavior script inline to toggle grid display -->
  <script is:inline>
    (() => {
      const init = () => {
        const btn = document.getElementById('toggle-testimonials-btn');
        const grid = document.getElementById('testimonials-grid');
        if (!btn || !grid) return;
        
        // Remove click listener if already present (to avoid double bindings on hydration)
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);

        newBtn.addEventListener('click', () => {
          const isExpanded = newBtn.getAttribute('aria-expanded') === 'true';
          const hiddenCards = grid.querySelectorAll('.hidden-card');
          const visibleHiddenCards = grid.querySelectorAll('.tcard:not(.hidden-card)[data-was-hidden="true"]');
          
          if (isExpanded) {
            // Collapse
            visibleHiddenCards.forEach(card => {
              card.style.opacity = '0';
              setTimeout(() => {
                card.classList.add('hidden-card');
                card.removeAttribute('data-was-hidden');
              }, 200);
            });
            newBtn.setAttribute('aria-expanded', 'false');
            newBtn.querySelector('span').textContent = 'Show More Testimonials';
            
            // Scroll smoothly back to section header
            const header = document.getElementById('testimonials-title');
            if (header) {
              header.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          } else {
            // Expand
            const cardsToReveal = grid.querySelectorAll('.hidden-card');
            cardsToReveal.forEach(card => {
              card.classList.remove('hidden-card');
              card.setAttribute('data-was-hidden', 'true');
              card.style.opacity = '0';
              card.style.transform = 'translateY(15px)';
              card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
              
              // Force reflow
              void card.offsetHeight;
              
              card.style.opacity = '1';
              card.style.transform = 'translateY(0)';
            });
            newBtn.setAttribute('aria-expanded', 'true');
            newBtn.querySelector('span').textContent = 'Show Less Testimonials';
          }
        });
      };

      // Run on page load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</section>
