---
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import StatsSection from '../components/StatsSection.astro';
import Layout from '../layouts/BaseLayout.astro';
import vaRates from '../data/vaRates.json';

const title = `${vaRates.metadata.year} VA Disability Pay Rates | Veterans Disability Network`;
const description = `View complete ${vaRates.metadata.year} VA disability pay rates with ${vaRates.metadata.colaIncrease} COLA increase. Find your exact monthly compensation amount using our updated rate tables and charts.`;
---

<Layout title={title} description={description}>
  <SiteHeader /> <!-- header component -->
  <StatsSection /> <!-- stats section component -->
  <SiteFooter /> <!-- footer component -->
</Layout>